{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "romulus",
  "version": "0.1.0",
  "description": "ROM collection verification system",
  "license": "MIT",
  "dependencies": [
    "sqlite3",
    "spdlog",
    "pugixml",
    "cli11",
    "libarchive",
    "openssl",
    "nlohmann-json",
    "gtest",
    {
      "name": "imgui",
      "features": ["glfw-binding", "opengl3-binding"],
      "platform": "!android & !ios"
    },
    {
      "name": "glfw3",
      "platform": "!android & !ios"
    }
  ]
}
